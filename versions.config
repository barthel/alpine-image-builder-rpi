# Alpine OS rootfs version to use
# Set to the tagged release of alpine-os-rootfs, e.g. "0.1.0"
# For local builds, place the tarball in the project root and set to "dirty"
ALPINE_OS_VERSION="dirty"
ROOTFS_TAR_CHECKSUM=""

# Alpine version (full: major.minor.patch) — must match the rootfs build
ALPINE_VERSION="3.21.0"
